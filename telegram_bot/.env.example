# Copiază acest fișier în ".env" și completează valorile tale.

# 1) Tokenul botului de Telegram (de la @BotFather)
TELEGRAM_TOKEN=pune_aici_tokenul_de_la_botfather

# 2) Cheia Groq (GRATIS, fără card) de la console.groq.com -> API Keys
GROQ_API_KEY=pune_aici_cheia_groq

# 3) (opțional) modelul Groq folosit.
#    llama-3.3-70b-versatile -> cel mai bun (recomandat)
#    llama-3.1-8b-instant    -> mai rapid, mai simplu
GROQ_MODEL=llama-3.3-70b-versatile
